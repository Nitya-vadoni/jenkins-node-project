pipeline {
    agent any

    stages {
        stage('Deploy to Node VM') {
            steps {
                sshagent(['ubuntu']) {
                    sh '''
                    ssh -o StrictHostKeyChecking=no ubuntu@172.31.15.245 "
                        cd /home/ubuntu/Node/app &&
                        git pull origin main &&
                        npm install &&
                        pm2 restart nodeapp || pm2 start app.js  --name nodeapp
                    "
                    '''
                }
            }
        }
    }

    post {
        success {
            echo "Deployment Successful!"
        }
        failure {
            echo "Deployment Failed!"
        }
    }
}
